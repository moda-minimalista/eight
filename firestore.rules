rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == "admin";
    }

    match /produtos/{productId} {
      allow read: if isAdmin() || resource.data.ativo == true;
      allow create, update, delete: if isAdmin();
    }

    match /categorias/{categoryId} {
      allow read: if isAdmin() || resource.data.ativo == true;
      allow create, update, delete: if isAdmin();
    }

    match /cupons/{couponId} {
      allow read, write: if isAdmin();
    }

    match /configuracoes/{configId} {
      allow read, write: if isAdmin();
    }

    match /usuarios/{userId} {
      allow create: if isOwner(userId)
        && request.resource.data.role == "cliente"
        && request.resource.data.email == request.auth.token.email;
      allow read: if isOwner(userId) || isAdmin();
      allow update: if isAdmin()
        || (isOwner(userId)
          && request.resource.data.role == resource.data.role
          && request.resource.data.email == resource.data.email);
      allow delete: if isAdmin();

      match /carrinho/{cartId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /pedidos/{orderId} {
      allow create: if signedIn()
        && request.resource.data.usuarioId == request.auth.uid
        && request.resource.data.status == "Aguardando pagamento"
        && request.resource.data.valorTotal >= 0;
      allow read: if isAdmin()
        || (signedIn() && resource.data.usuarioId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
  }
}
